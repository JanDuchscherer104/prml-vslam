{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/scripts/mempalace_startup_context.sh\"",
            "statusMessage": "Refreshing MemPalace context"
          }
        ]
      }
    ]
  }
}

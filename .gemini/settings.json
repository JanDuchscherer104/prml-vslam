{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "/Docker/host/bin/docker.exe",
      "args": [
        "mcp",
        "gateway",
        "run",
        "--profile",
        "codex"
      ]
    },
    "code-index": {
      "command": "uvx",
      "args": [
        "code-index-mcp"
      ]
    },
    "graphify": {
      "command": "uv",
      "args": [
        "run",
        "--preview-features",
        "extra-build-dependencies",
        "--group",
        "dev",
        "python",
        "-m",
        "graphify.serve",
        "graphify-out/graph.json"
      ]
    },
    "mempalace": {
      "command": "bash",
      "args": [
        "-lc",
        "cd \"$(git rev-parse --show-toplevel)\" && exec .venv/bin/python -m mempalace.mcp_server --palace .artifacts/mempalace/palace"
      ]
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "read_file|list_directory",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"decision\":\"allow\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}' || echo '{\"decision\":\"allow\"}'"
          }
        ]
      }
    ]
  },
  "general": {
    "defaultApprovalMode": "auto_edit"
  }
}
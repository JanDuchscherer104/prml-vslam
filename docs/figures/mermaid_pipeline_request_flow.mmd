sequenceDiagram
    autonumber
    actor User
    participant Surface as CLI or Pipeline page
    participant Demo as pipeline.demo
    participant Paths as PathConfig
    participant Request as RunRequest
    participant Planner as RunPlannerService
    participant RunSvc as RunService
    participant Session as PipelineSessionService
    participant Source as StreamingSequenceSource
    participant Backend as MockSlamBackend

    User->>Surface: Choose persisted pipeline request TOML
    Surface->>Demo: load_run_request_toml(config_path)
    Demo->>Paths: resolve_pipeline_config_path(...)
    Demo->>Request: RunRequest.from_toml(...)
    Demo-->>Surface: RunRequest
    Surface->>Planner: build_run_plan(request)
    Planner->>Paths: plan_run_paths(...)
    Planner-->>Surface: RunPlan

    alt Planning only
        Surface-->>User: Render or print RunPlan
    else Bounded demo execution
        Surface->>RunSvc: start_run(request, source)
        RunSvc->>Planner: build_run_plan(request)
        Planner-->>RunSvc: RunPlan
        RunSvc->>Session: start(request, plan, source, slam_backend)
        Session->>Source: prepare_sequence_manifest(...)
        Source-->>Session: SequenceManifest
        Session->>Source: open_stream(loop=...)
        Session->>Backend: start_session(request.slam, artifact_root)
        loop For each frame
            Source-->>Session: FramePacket
            Session->>Backend: step(frame)
            Backend-->>Session: SlamUpdate
        end
        Session->>Backend: close()
        Backend-->>Session: SlamArtifacts
        Session-->>Surface: RunSummary + StageManifest[]
        Surface-->>User: Monitor artifacts and summary
    end

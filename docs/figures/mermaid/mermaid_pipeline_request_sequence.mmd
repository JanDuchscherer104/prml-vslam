%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontSize": "28px",
    "actorFontSize": "28px",
    "messageFontSize": "24px",
    "noteFontSize": "22px",
    "sequenceNumberFontSize": "22px"
  }
}}%%
sequenceDiagram
    autonumber

    actor User as User

    box rgb(232, 241, 255) Planning and launch surfaces
        participant Surface as app.pages.pipeline<br/>or prml_vslam.main
        participant Demo as pipeline.demo
        participant Planner as pipeline.services<br/>RunPlannerService
    end

    box rgb(255, 244, 229) Pipeline runtime
        participant Runtime as pipeline.run_service<br/>RunService
        participant Backend as pipeline.backend_ray<br/>RayPipelineBackend
        participant Coord as pipeline.ray_runtime.coordinator<br/>RunCoordinatorActor
        participant Source as pipeline.ray_runtime.stage_actors<br/>PacketSourceActor
        participant Slam as pipeline.ray_runtime.stage_actors<br/>StreamingSlamStageActor
    end

    User->>Surface: choose request
    Surface->>Demo: load_run_request_toml(config_path)
    Demo-->>Surface: request: RunRequest
    Surface->>Planner: build_run_plan(request)
    Planner-->>Surface: plan: RunPlan

    alt preview only
        Surface-->>User: show RunPlan
    else bounded execution
        Surface->>Runtime: start_run(request, source)
        Runtime->>Planner: build_run_plan(request)
        Planner-->>Runtime: plan: RunPlan
        Runtime->>Backend: submit_run(request, source)
        Backend->>Coord: start(request, plan, source)
        Coord->>Source: start_stream(source, credits)
        Coord->>Slam: start_stage(request, plan)
        loop each packet
            Source-->>Coord: packet observed
            Coord->>Slam: push_frame(...)
            Slam-->>Coord: backend notices
        end
        Coord->>Slam: close_stage()
        Slam-->>Coord: slam: SlamArtifacts
        Runtime-->>Surface: summary: RunSummary + StageManifest[]
        Surface-->>User: inspect artifacts and summary
    end

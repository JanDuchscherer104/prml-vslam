  "theme": "base",
  "themeVariables": {
    "fontSize": "28px",
    "actorFontSize": "28px",
    "messageFontSize": "24px",
    "noteFontSize": "22px",
    "sequenceNumberFontSize": "22px"
  }
}}%%
sequenceDiagram
    autonumber

    actor User as User

    box rgb(232, 241, 255) Planning and launch surfaces
        participant Surface as app.pages.pipeline<br/>or prml_vslam.main
        participant RunConfig as pipeline.config<br/>RunConfig
    end

    box rgb(255, 244, 229) Pipeline runtime
        participant Runtime as pipeline.run_service<br/>RunService
        participant Backend as pipeline.backend_ray<br/>RayPipelineBackend
        participant Coord as pipeline.ray_runtime.coordinator<br/>RunCoordinatorActor
        participant RuntimeMgr as pipeline.runtime_manager<br/>RuntimeManager
        participant Proxy as pipeline.stages.base.proxy<br/>StageRuntimeHandle
        participant SlamRuntime as methods.stage.runtime<br/>SlamStageRuntime
    end

    User->>Surface: choose request
    Surface->>RunConfig: compile_plan()
    RunConfig-->>Surface: plan: RunPlan

    alt preview only
        Surface-->>User: show RunPlan
    else bounded execution
        Surface->>Runtime: start_run(request)
        Runtime->>RunConfig: compile_plan()
        RunConfig-->>Runtime: plan: RunPlan
        Runtime->>Backend: submit_run(request)
        Backend->>Coord: start(request, plan)
        Coord->>RuntimeMgr: preflight + build slam runtime proxy
        RuntimeMgr-->>Coord: Proxy: StageRuntimeHandle

        alt streaming mode
            Coord->>Proxy: start_streaming(...)
            Proxy->>SlamRuntime: start_streaming(...)
            loop each Observation
                Coord->>Proxy: submit_stream_item(item)
                Proxy->>SlamRuntime: submit_stream_item(item)
                Coord->>Proxy: drain_runtime_updates()
                Proxy-->>Coord: updates: StageRuntimeUpdate[]
            end
            Coord->>Proxy: finish_streaming()
            Proxy-->>Coord: result: StageResult
        else offline mode
            Coord->>Proxy: run_offline(...)
            Proxy->>SlamRuntime: run_offline(...)
            SlamRuntime-->>Proxy: StageResult
            Proxy-->>Coord: StageResult
        end

        Runtime-->>Surface: snapshot: RunSnapshot
        Surface-->>User: inspect artifacts and summary
    end

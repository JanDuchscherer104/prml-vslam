flowchart TD
    user(["User"])
    surface["CLI or Pipeline page"]
    preview["Plan preview"]

    subgraph planning["Planning phase"]
        toml[["Persisted pipeline TOML"]]
        load["load_run_request_toml()"]
        request["RunConfig"]
        paths["resolve_pipeline_config_path()"]
        planner["build_run_plan()"]
        plan["RunPlan"]
    end

    subgraph launch["Launch and coordination"]
        runsvc["RunService.start_run()"]
        backend["RayPipelineBackend.submit_run()"]
        coord["RunCoordinatorActor.start()"]
        ingest["IngestStageActor.run()"]
        manifest["SequenceManifest"]
        source["PacketSourceActor.start_stream()"]
        slam_start["StreamingSlamStageActor.start_stage()"]
    end

    subgraph hotpath["Streaming SLAM hot path"]
        frame["StageRuntimeUpdate source status"]
        step["StreamingSlamStageActor.push_frame()"]
        update["StageRuntimeUpdate semantic events and visualizations"]
        snapshot["Projected snapshot and runtime metrics"]
    end

    subgraph finalize["Finalization"]
        close["StreamingSlamStageActor.close_stage()"]
        artifacts["SlamArtifacts"]
        summary["SummaryStageActor -> RunSummary and StageManifest[]"]
    end

    user -->|"choose request"| surface
    surface -->|"load template"| toml
    toml -->|"resolve repo path"| paths
    paths -->|"hydrate request"| load
    load --> request
    request -->|"plan run"| planner
    planner --> plan
    plan -->|"preview only"| preview
    plan -->|"bounded execution"| runsvc

    runsvc --> backend
    backend --> coord
    coord --> ingest
    ingest --> manifest
    coord --> source
    coord --> slam_start

    source -->|"for each packet"| frame
    frame --> step
    step --> update
    update --> snapshot

    slam_start -->|"terminal close"| close
    close --> artifacts
    manifest --> summary
    artifacts --> summary
    snapshot --> summary

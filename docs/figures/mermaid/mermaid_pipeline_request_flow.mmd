flowchart TD
    user(["User"])
    surface["CLI or Pipeline page"]
    preview["Plan preview"]

    subgraph planning["Planning phase"]
        toml[["Persisted pipeline TOML"]]
        config["RunConfig"]
        plan["RunPlan"]
        compile["RunConfig.compile_plan()"]
    end

    subgraph launch["Launch and coordination"]
        runsvc["RunService.start_run()"]
        backend["RayPipelineBackend.submit_run()"]
        coord["RunCoordinatorActor.start()"]
        rtmgr["RuntimeManager"]
        proxy["StageRuntimeHandle"]
    end

    subgraph execution["Stage Execution"]
        offline["OfflineStageRuntime.run_offline()"]
        streaming["StreamingStageRuntime.submit_stream_item()"]
        updates["StageRuntimeUpdate semantic events and visualizations"]
        snapshot["Projected RunSnapshot and StageRuntimeStatus"]
    end

    subgraph finalization["Finalization"]
        result["StageResult"]
        outcome["StageOutcome"]
        summary["RunSummary and StageManifest[]"]
    end

    user -->|"choose request"| surface
    surface -->|"load"| toml
    toml --> config
    config -->|"compile"| compile
    compile --> plan
    plan -->|"preview only"| preview
    plan -->|"bounded execution"| runsvc

    runsvc --> backend
    backend --> coord
    coord --> rtmgr
    rtmgr -->|"build proxy"| proxy

    proxy -->|"offline"| offline
    proxy -->|"streaming"| streaming
    streaming --> updates
    offline --> result
    streaming -->|"finish"| result

    updates --> snapshot
    result --> outcome
    outcome --> summary
    snapshot --> summary

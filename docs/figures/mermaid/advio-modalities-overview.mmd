  style IPA fill:#f8fbff,stroke:#94a3b8,color:#1f2937
  style IPIMU fill:#f8fbff,stroke:#94a3b8,color:#1f2937
  style IPB fill:#f8fbff,stroke:#94a3b8,color:#1f2937
  style IPL fill:#f8fbff,stroke:#94a3b8,color:#1f2937

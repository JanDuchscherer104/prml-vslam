%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontSize": "16px",
    "actorFontSize": "16px",
    "messageFontSize": "15px",
    "noteFontSize": "14px",
    "sequenceNumberFontSize": "13px"
  }
}}%%
sequenceDiagram
    autonumber

    participant Caller as App / CLI
    participant Service as RunService
    participant Backend as RayPipelineBackend
    participant Coord as RunCoordinatorActor
    participant RtmMgr as RuntimeManager
    participant Source as SourceRuntime
    participant Packet as PacketSourceActor
    participant Proxy as StageRuntimeHandle
    participant Slam as SlamStageRuntime
    participant Summary as SummaryRuntime

    Caller->>Service: start_run(request)
    Service->>Backend: submit_run(request)
    Backend->>Backend: request.build(path_config)
    Backend->>Coord: start(request, plan)
    Coord->>RtmMgr: preflight(request, plan)
    Coord->>Coord: record run.submitted and run.started

    Coord->>RtmMgr: runtime_for(source)
    RtmMgr-->>Coord: SourceRuntime
    Coord->>Source: run_offline(...)
    Source-->>Coord: StageResult (SequenceManifest)

    Coord->>RtmMgr: runtime_for(slam)
    RtmMgr-->>Coord: Proxy (Slam)
    Coord->>Proxy: start_streaming(...)
    Proxy->>Slam: start_streaming(...)

    Coord->>Packet: start_stream(source, initial_credits)
    loop packet credit loop
        Packet->>Source: wait_for_observation()
        Source-->>Packet: Observation
        Packet-->>Coord: on_packet(observation)
        Coord->>Proxy: submit_stream_item(observation)
        Proxy->>Slam: submit_stream_item(observation)
        Coord->>Proxy: drain_runtime_updates()
        Proxy-->>Coord: StageRuntimeUpdate[]
        Coord->>Coord: publish updates
        Coord->>Packet: grant_credit(1)
    end

    alt source EOF or error
        Packet-->>Coord: on_source_eof() / on_source_error()
    end

    Coord->>Proxy: finish_streaming()
    Proxy->>Slam: finish_streaming()
    Slam-->>Proxy: StageResult
    Proxy-->>Coord: StageResult

    opt trajectory evaluation enabled and no stop/error
        Coord->>RtmMgr: runtime_for(evaluate.trajectory)
        RtmMgr-->>Coord: TrajectoryEvaluationRuntime
        Coord->>TrajectoryEvaluationRuntime: run_offline(...)
        TrajectoryEvaluationRuntime-->>Coord: StageResult
    end

    Coord->>RtmMgr: runtime_for(summary)
    RtmMgr-->>Coord: SummaryRuntime
    Coord->>Summary: run_offline(stage_outcomes)
    Summary-->>Coord: StageResult
    Coord->>Coord: emit run.completed / run.failed / run.stopped
